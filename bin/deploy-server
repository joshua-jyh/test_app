#!/usr/bin/env sh

set -eu

ACTION="${1:-restart}"
RAILS_ENV="${RAILS_ENV:-staging}"
PORT="${PORT:-3001}"
PIDFILE="${PIDFILE:-tmp/pids/puma.pid}"
LOGFILE="${LOGFILE:-log/puma.log}"

owned_puma() {
  pid="$1"
  [ "$(ps -o uid= -p "$pid" | tr -d ' ')" = "$(id -u)" ] || return 1
  ps -o args= -p "$pid" | grep -q '[p]uma'
}

pid_from_file() {
  [ -f "$PIDFILE" ] || return 1

  pid="$(cat "$PIDFILE")"
  case "$pid" in
    *[!0-9]*|"") return 1 ;;
  esac

  kill -0 "$pid" 2>/dev/null || return 1
  owned_puma "$pid" || return 1
  printf '%s\n' "$pid"
}

listener_pid() {
  if command -v lsof >/dev/null 2>&1; then
    lsof -nP -t -iTCP:"$PORT" -sTCP:LISTEN 2>/dev/null | head -n 1
  elif command -v fuser >/dev/null 2>&1; then
    fuser -n tcp "$PORT" 2>/dev/null | awk '{ print $1 }'
  fi
}

managed_puma_pid() {
  pid="$(pid_from_file 2>/dev/null || true)"
  if [ -n "$pid" ]; then
    printf '%s\n' "$pid"
    return
  fi

  pid="$(listener_pid || true)"
  [ -n "$pid" ] || return 1
  owned_puma "$pid" || return 1

  printf '%s\n' "$pid"
}

running() {
  managed_puma_pid >/dev/null 2>&1
}

stop_server() {
  pid="$(managed_puma_pid 2>/dev/null || true)"
  if [ -z "$pid" ]; then
    rm -f "$PIDFILE"
    echo "Puma is not running."
    return
  fi

  kill -TERM "$pid"

  attempts=0
  while kill -0 "$pid" 2>/dev/null; do
    attempts=$((attempts + 1))
    if [ "$attempts" -ge 30 ]; then
      echo "Puma did not stop within 30 seconds." >&2
      exit 1
    fi
    sleep 1
  done

  rm -f "$PIDFILE"
  echo "Puma stopped."
}

start_server() {
  if running; then
    echo "Puma is already running with PID $(managed_puma_pid)."
    return
  fi

  pid="$(listener_pid || true)"
  if [ -n "$pid" ]; then
    echo "Port $PORT is already used by PID $pid, which is not a managed Puma process." >&2
    exit 1
  fi

  mkdir -p "$(dirname "$PIDFILE")" "$(dirname "$LOGFILE")"
  rm -f "$PIDFILE"

  setsid env \
    RAILS_ENV="$RAILS_ENV" \
    PORT="$PORT" \
    PIDFILE="$PIDFILE" \
    RAILS_SERVE_STATIC_FILES=true \
    bundle exec puma -C config/puma.rb \
    </dev/null >>"$LOGFILE" 2>&1 &

  attempts=0
  until running; do
    attempts=$((attempts + 1))
    if [ "$attempts" -ge 15 ]; then
      echo "Puma failed to start. Check $LOGFILE." >&2
      exit 1
    fi
    sleep 1
  done

  echo "Puma started on 0.0.0.0:$PORT with PID $(cat "$PIDFILE")."
}

case "$ACTION" in
  start)
    start_server
    ;;
  stop)
    stop_server
    ;;
  restart)
    stop_server
    start_server
    ;;
  status)
    if running; then
      echo "Puma is running with PID $(managed_puma_pid) on port $PORT."
    else
      echo "Puma is not running."
      exit 1
    fi
    ;;
  *)
    echo "Usage: $0 {start|stop|restart|status}" >&2
    exit 2
    ;;
esac
